pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                echo "Building the project..."
            }
        }

        stage('Deploy to Dev') {
            when {
                expression { return true } // This stage will run only if the expression is true
            }
            steps {
                echo "Deploying to Development Environment"
            }
        }

        stage('Deploy to Prod') {
            when {
                expression { return false } // This stage will NOT run
            }
            steps {
                echo "Deploying to Production Environment"
            }
        }

    }
}