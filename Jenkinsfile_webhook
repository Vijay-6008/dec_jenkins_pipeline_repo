pipeline {
    agent any

    parameters {
        string(name: 'username', defaultValue: 'guest', description: 'User name')
        string(name: 'action', defaultValue: 'test', description: 'Action type')
    }

    stages {
        stage('Webhook Received') {
            steps {
                echo "Webhook triggered!"
                echo "User: ${params.username}"
                echo "Action: ${params.action}"
            }
        }

        stage('Process Data') {
            steps {
                sh """
                echo "Processing webhook data..."
                echo "User = ${params.username}"
                echo "Action = ${params.action}"
                """
            }
        }

        stage('Finish') {
            steps {
                echo "Pipeline completed successfully"
            }
        }
    }
}