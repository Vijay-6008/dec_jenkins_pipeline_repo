pipeline {
    agent any

    environment{
        CURRENT_ENV = 'prodaa'
    }

    stages {

        stage('Checkout REPLAY') {
            steps {
                checkout{[$class:'GIT_SCM',
                branches:[[name: '*/main']],
                extension:[],
                userRemoteConfigs: [[
                    credentialsId: '',
                    url: ''
                ]]
                ]}

        sh '''
        echo GIT_BRANCH: $GIT_BRANCH
        echo BRANCH_NAME: $BRANCH_NAME
        '''
            }
        }
        stage('stage1 when branch main'){
            when{
                expression{
                    return env.GIT_BRANCH == 'origin/main'
                }
            }
            steps{
                echo 'this is stage1 running'
                sh '''
                    pwd
                    ls -lrt
                    sleep 5
                    '''
            }
        }  
    