pipeline {
    agent any

    stages {

        stage('Run Python Script') {
            steps {
                sh 'python3 --version'
                sh 'python3 script.py'
            }
        }

        stage('Archive Output') {
            steps {
                archiveArtifacts artifacts: 'build_output.txt', fingerprint: true
            }
        }
    }

    post {
        success {
            echo 'Build completed successfully!'
        }
        failure {
            echo 'Build failed!'
        }
    }
}