pipeline {
    agent any   

    stages {
        stage('Check System Info') {
            steps {
                sh 'echo Running on:'
                sh 'hostname'
                sh 'whoami'
                sh 'pwd'
            }
        }
    }
}

pipeline {
    agent { label 'slave_two' }   
    stages {
        stage('Check Agent') {
            steps {
                echo "Running on labeled agent"
                sh 'hostname'
                sh 'whoami'
            }
        }
    }
}